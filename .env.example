# 环境变量模板（兼容入口）
# 权威完整模板：cp .env.local.example .env.local
# Auth / Admin / Embed / 资源库 / Sentry 见 .env.local.example

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
AUTH_SECRET=your-auth-secret
ADMIN_PASSWORD_HASH=
# 仅本地开发可临时用明文；生产必须 HASH
# ADMIN_PASSWORD=

NEXT_PUBLIC_SITE_URL=https://yuanjia1314.ccwu.cc

# 资源库仅服务端 key，禁止 NEXT_PUBLIC_ 前缀
# RESOURCE_LIBRARY_API_KEY=
# RESOURCE_LIBRARY_ANON_KEY=
# RESOURCE_LIBRARY_SERVICE_ROLE_KEY=

# 远程 embed
# EMBED_SERVER_URL=https://nav-site-embed-proxy.xiej4352.workers.dev
# EMBED_SERVER_API_KEY=

# 生产探针可选：embedding 必须 ok
# HEALTH_REQUIRE_EMBEDDING=1
